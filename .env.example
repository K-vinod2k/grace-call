# Copy to .env and fill in. NEVER commit .env (see .gitignore).
# All values are placeholders — replace with your own from the Azure portal.

# --- Azure Communication Services (Call Automation) ---
# Azure portal > your ACS resource > Keys > Connection string
ACS_CONNECTION_STRING=endpoint=https://YOUR-ACS.communication.azure.com/;accesskey=PLACEHOLDER
# An outbound-capable number you purchased in ACS (E.164). BUY THIS FIRST — longest lead time.
ACS_CALLER_ID=+15551234567

# --- Public callback base URL ---
# ACS posts call events here and connects the media WebSocket here.
# Local dev: a dev tunnel / ngrok HTTPS URL. Prod: your deployed host.
CALLBACK_BASE_URL=https://your-tunnel.example.com

# --- Azure Voice Live API (Azure AI Foundry / Speech) ---
# Foundry/Speech resource endpoint + key. Pick a North-America region (gpt-realtime availability).
VOICE_LIVE_ENDPOINT=wss://YOUR-REGION.api.cognitive.microsoft.com
VOICE_LIVE_API_KEY=PLACEHOLDER
VOICE_LIVE_MODEL=gpt-realtime
VOICE_LIVE_VOICE=en-US-AvaNeural

# --- Trigger auth ---
# Shared secret Copilot Studio's custom connector sends in the X-GraceCall-Key header.
TRIGGER_API_KEY=run-`openssl-rand-hex-32`-and-paste-here

# --- SMS confirmation (optional; ACS SMS or leave blank to log only) ---
ACS_SMS_FROM=+15551234567

# --- Server ---
PORT=8080
# Local dev only: relax ACS webhook signature checks. NEVER set to 1 in prod.
SKIP_ACS_SIGNATURE_CHECK=0

# --- Live conversation (Day-1) ---
# 0 = ring + play a fixed AI-disclosure TTS line, then hang up. No Voice Live needed — use this for
#     your FIRST test (just prove the phone rings and talks).
# 1 = full two-way conversation: ACS streams 24kHz audio to /acs/media and Voice Live drives the call.
ENABLE_MEDIA_STREAMING=0

# --- Autonomous dialing (the "agent decides when to call" behavior) ---
# 0 = you trigger each call manually (POST /trigger-call, `npm run trigger:demo`, or from Copilot Studio).
# 1 = a built-in scheduler checks every minute and auto-calls any rental overdue by AUTO_DIAL_AFTER_MIN
#     minutes (skipping do-not-call). This dials REAL numbers — keep 0 until you're ready.
AUTO_DIAL=0
AUTO_DIAL_AFTER_MIN=60
