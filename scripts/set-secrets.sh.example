#!/usr/bin/env bash
# =============================================================================
# GraceCall — Container Apps secrets template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp scripts/set-secrets.sh.example scripts/set-secrets.sh
#   2. Fill in every <VALUE> placeholder with the real secret from your .env
#   3. Run:  bash scripts/set-secrets.sh
#   4. NEVER commit scripts/set-secrets.sh  (it's in .gitignore)
#
# This script uses TWO az commands:
#   a) az containerapp secret set  — stores the secret in Container Apps' secret store
#      (encrypted at rest; not visible in az containerapp show output)
#   b) az containerapp update --set-env-vars  — wires a secret-ref into an env var
#      so the Node.js process sees it as process.env.MY_VAR
#
# Run deploy-azure.sh first to create the Container App, then run this script.
# =============================================================================

set -euo pipefail

RESOURCE_GROUP="gracecall-rg"
APP_NAME="grace-call"

echo "▶ Setting Container Apps secrets for ${APP_NAME}..."

# -----------------------------------------------------------------------------
# Step 1 — Register all secrets in the Container Apps secret store
# Each entry: --secrets <secret-name>=<secret-value>
# secret-name must be lowercase alphanumeric + hyphens (no underscores)
# -----------------------------------------------------------------------------
az containerapp secret set \
  --name "${APP_NAME}" \
  --resource-group "${RESOURCE_GROUP}" \
  --secrets \
    acs-connection-string="<ACS_CONNECTION_STRING>" \
    acs-caller-id="<ACS_CALLER_ID>" \
    voice-live-api-key="<VOICE_LIVE_API_KEY>" \
    trigger-api-key="<TRIGGER_API_KEY>" \
    groq-api-key="<GROQ_API_KEY>" \
    acs-sms-from="<ACS_SMS_FROM>" \
    callback-base-url="<CALLBACK_BASE_URL>"

echo "   ✅ Secrets registered."

# -----------------------------------------------------------------------------
# Step 2 — Wire secrets as env vars AND set plain (non-secret) env vars
# Format for secret references: KEY=secretref:<secret-name>
# Format for plain values:       KEY=value
# -----------------------------------------------------------------------------
az containerapp update \
  --name "${APP_NAME}" \
  --resource-group "${RESOURCE_GROUP}" \
  --set-env-vars \
    ACS_CONNECTION_STRING=secretref:acs-connection-string \
    ACS_CALLER_ID=secretref:acs-caller-id \
    VOICE_LIVE_ENDPOINT="<VOICE_LIVE_ENDPOINT>" \
    VOICE_LIVE_API_KEY=secretref:voice-live-api-key \
    VOICE_LIVE_MODEL="<VOICE_LIVE_MODEL>" \
    VOICE_LIVE_VOICE="<VOICE_LIVE_VOICE>" \
    TRIGGER_API_KEY=secretref:trigger-api-key \
    GROQ_API_KEY=secretref:groq-api-key \
    ACS_SMS_FROM=secretref:acs-sms-from \
    CALLBACK_BASE_URL=secretref:callback-base-url \
    COGNITIVE_SERVICES_ENDPOINT="<COGNITIVE_SERVICES_ENDPOINT>" \
    NODE_ENV=production \
    PORT=8080 \
    SKIP_ACS_SIGNATURE_CHECK=0 \
    ENABLE_MEDIA_STREAMING=1 \
    AUTO_DIAL=0 \
    AUTO_DIAL_AFTER_MIN=60 \
    RECHECK_AFTER_MIN=2

echo "   ✅ Env vars wired."
echo ""
echo "▶ Current env var bindings:"
az containerapp show \
  --name "${APP_NAME}" \
  --resource-group "${RESOURCE_GROUP}" \
  --query "properties.template.containers[0].env" \
  -o table

echo ""
echo "✅ All secrets set. The Container App will restart automatically."
echo ""
echo "Verify the app is healthy:"
FQDN=$(az containerapp show \
  --name "${APP_NAME}" \
  --resource-group "${RESOURCE_GROUP}" \
  --query "properties.configuration.ingress.fqdn" -o tsv)
echo "   curl https://${FQDN}/health"
